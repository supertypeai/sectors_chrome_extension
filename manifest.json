{
  "manifest_version": 3,
  "name": "Sectors IDX Ticker Lens",
  "version": "1.0.0",
  "description": "Hover over any IDX ticker to get real-time company data, insider filings, and news from Sectors.app",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.sectors.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["tooltip.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/favicon-16x16.png",
      "32": "icons/favicon-32x32.png",
      "48": "icons/android-chrome-192x192.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/favicon-16x16.png",
    "32": "icons/favicon-32x32.png",
    "48": "icons/android-chrome-192x192.png",
    "128": "icons/android-chrome-192x192.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/android-chrome-192x192.png",
        "icons/favicon-32x32.png",
        "icons/favicon-16x16.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
